generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CategoryType {
  EXPENSE
  INCOME
  BOTH
}

enum TransactionKind {
  EXPENSE
  INCOME
}

enum AccountType {
  CARD
  DEBIT_CARD
  CREDIT_CARD
  CASH
  BANK
  DEPOSIT
  SAVINGS
  OTHER
}

enum InvestmentAssetKind {
  STOCK
  BOND
  FUND
  CRYPTO
  OTHER
}

/// Шаг отчётности для сводок и прогноза (см. API summary/reporting).
enum FinanceReportingGranularity {
  DAY
  WEEK
  MONTH
  YEAR
  CUSTOM
}

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  /// С какого числа каждого месяца ведётся отчётный период (1–28), если гранулярность MONTH.
  financeReportingDay Int          @default(1)
  financeReportingGranularity FinanceReportingGranularity @default(MONTH)
  /// При гранулярности CUSTOM: начало диапазона YYYY-MM-DD (локальный календарь клиента + tzOffset в API).
  financeReportingCustomFrom String?
  /// При гранулярности CUSTOM: конец диапазона YYYY-MM-DD включительно.
  financeReportingCustomTo   String?
  createdAt    DateTime             @default(now())
  categories   Category[]
  transactions Transaction[]
  accounts     Account[]
  investments  InvestmentPosition[]
  transfers    Transfer[]
  categoryBudgets CategoryBudget[]
}

model Account {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  /// Годовая ставка, % (вклады, накопительные; опционально — счёт с процентом на остаток).
  annualInterestPercent Float?
  /// Последний календарный день Europe/London, за который создано ежедневное начисление %% (YYYY-MM-DD).
  lastInterestAccrualLondonDate String?
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  transfersOut Transfer[]    @relation("TransferFromAccount")
  transfersIn  Transfer[]    @relation("TransferToAccount")

  @@index([userId])
}

model Transfer {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccountId String
  fromAccount   Account  @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccountId   String
  toAccount     Account  @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)
  amountMinor   Int
  note          String?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model Category {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        CategoryType
  isBuiltIn   Boolean         @default(false)
  isArchived  Boolean         @default(false)
  sortOrder   Int             @default(0)
  /// Не учитывать в доходах/расходах отчётного периода (корректировка баланса счёта).
  excludeFromReporting Boolean @default(false)
  /// Родительская категория (подкатегории — один уровень вложенности).
  parentId    String?
  parent      Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]      @relation("CategoryHierarchy")
  /// Эмодзи-иконка для виджета (например 🍕).
  iconEmoji   String?
  /// Акцентный цвет виджета (#RRGGBB или ключ темы).
  accentColor String?
  createdAt   DateTime        @default(now())
  transactions Transaction[]
  budgets      CategoryBudget[]

  @@index([userId])
  @@index([userId, parentId])
}

/// Лимит расходов по категории за календарный месяц (YYYY-MM).
model CategoryBudget {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  periodYm   String
  limitMinor Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, periodYm])
  @@index([userId, periodYm])
}

model Transaction {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  kind        TransactionKind
  amountMinor Int
  note        String?
  occurredAt  DateTime
  createdAt   DateTime         @default(now())

  @@index([userId, occurredAt])
  @@index([accountId])
}

model InvestmentPosition {
  id                        String              @id @default(uuid())
  userId                    String
  user                      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                      String
  assetKind                 InvestmentAssetKind
  units                     Float
  pricePerUnitMinor         Int
  /// Купоны+дивиденды в год с одной бумаги (коп.). Приоритет над legacy total ниже.
  annualIncomePerUnitMinor  Int?
  /// Устарело: годовой доход по всей позиции; если perUnit пусто — используется это.
  annualCouponDividendMinor Int?
  quoteSource               String?
  quoteExternalId           String?
  quoteMoexMarket           String?
  note                      String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@index([userId])
}
