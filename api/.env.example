# Копия: cp .env.example .env
PORT=3000
NODE_ENV=development

# Только не-production: POST /api/v1/auth/dev-login (кнопка «Войти как разработчик» в Vite dev)
# DEV_RELAXED_AUTH=1
# DEV_AUTH_EMAIL=dev@local.rh

# SQLite (разработка). В проде замените на PostgreSQL — см. README api/
DATABASE_URL="file:./dev.db"

# CORS: через запятую origins веб-клиента (и туннеля / прод-домена)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Tunnel: URL меняется при каждом запуске Quick Tunnel — можно включить (вместо правки CORS каждый раз):
# CORS_ALLOW_TRYCLOUDFLARE=1

# URL фронта без слэша — после OAuth редирект на главную
FRONTEND_URL=http://localhost:5173
# Для туннеля: FRONTEND_URL=https://ваш-хост.trycloudflare.com и те же базовые URL в GOOGLE_REDIRECT_URI и т.д.

# Подпись JWT и OAuth state (в проде — длинная случайная строка)
JWT_SECRET=change-me-in-production

# Принудительно Secure-cookie (редко нужно). Если вход «сбрасывается» за nginx без HTTPS к Node — оставьте авто:
# SESSION_COOKIE_SECURE=false

# --- OAuth: redirect URI = тот же origin, что у фронта + путь callback ---
# Локально с Vite: http://localhost:5173/api/v1/auth/<provider>/callback
# (прокси /api → API на :3000, чтобы cookie были на одном origin с SPA)

# Google Cloud Console → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/v1/auth/google/callback

# Яндекс OAuth: https://oauth.yandex.ru/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:5173/api/v1/auth/yandex/callback

# VK: https://dev.vk.com/ru/admin/apps-list (приложение, Redirect URI)
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=http://localhost:5173/api/v1/auth/vk/callback
