// Единая БД для веба и будущих мобильных клиентов (тот же API).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(uuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  email       String?         @unique
  displayName String?
  /// UI-настройки (JSON), например { "dashboardHints": true }
  settings    Json?
  accounts    OAuthAccount[]
  stats        UserStats?
  quests       Quest[]
  transactions Transaction[]
  kanbanCards  KanbanCard[]
}

/// Прогресс героя: уровень, EXP в текущем уровне, монеты, стрик.
model UserStats {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level          Int      @default(1)
  expInLevel     Int      @default(0)
  expToNext      Int      @default(100)
  coins          Int      @default(0)
  streakCount    Int      @default(0)
  /// UTC YYYY-MM-DD последнего дня, засчитанного в стрик
  lastStreakDate String?
  updatedAt      DateTime @updatedAt
}

/// Малый квест / привычка на сегодня.
model Quest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean   @default(false)
  rewardExp   Int       @default(10)
  rewardCoins Int       @default(0)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, done])
}

/// Доход / расход (сумма в копейках / центах, всегда > 0; тип задаёт знак в отчётах).
model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMinor Int
  type        String
  category    String
  note        String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, occurredAt])
}

/// Карточка канбана (колонки: todo | doing | done).
model KanbanCard {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  column    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, column])
}

/// Привязка к Google / Яндекс / VK / Apple (один пользователь — несколько провайдеров).
model OAuthAccount {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String
  providerAccountId  String
  createdAt          DateTime @default(now())

  @@unique([provider, providerAccountId])
}
