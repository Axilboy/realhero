// Единая БД для веба, Telegram Mini App и будущих Android/iOS (через тот же API).
// Для продакшена рекомендуется PostgreSQL: смените provider и DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  /// Telegram user id (строка, чтобы не упираться в int64 в разных клиентах)
  telegramId  String?  @unique
  displayName String?
}
