// Единая БД для веба и будущих мобильных клиентов (тот же API).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(uuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  email       String?         @unique
  displayName String?
  /// UI-настройки (JSON), например { "dashboardHints": true }
  settings    Json?
  accounts    OAuthAccount[]
}

/// Привязка к Google / Яндекс / VK / Apple (один пользователь — несколько провайдеров).
model OAuthAccount {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String
  providerAccountId  String
  createdAt          DateTime @default(now())

  @@unique([provider, providerAccountId])
}
