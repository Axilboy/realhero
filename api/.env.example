PORT=3000
NODE_ENV=development
DATABASE_URL="file:./dev.db"
# PostgreSQL (после docker compose up; см. корневой docker-compose.yml и api/README.md):
# DATABASE_URL="postgresql://realhero:realhero@127.0.0.1:5432/realhero"
JWT_SECRET=change-me-to-long-random-string

# Через запятую, без пробелов после запятой
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Опционально: общий cookie для www и без www (иначе сессия «теряется» при смене хоста)
# COOKIE_DOMAIN=.realherolife.ru

# По умолчанию в production cookie с Secure (только HTTPS). Если заходите по HTTP — задайте COOKIE_SECURE=false
# COOKIE_SECURE=false
