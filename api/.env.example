# Копия: cp .env.example .env
PORT=3000
NODE_ENV=development

# SQLite (разработка). В проде замените на PostgreSQL — см. README api/
DATABASE_URL="file:./dev.db"

# CORS: через запятую origins веб-клиента и будущих нативных оболочек (capacitor localhost и т.д.)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Позже: секрет бота для проверки Telegram WebApp initData
# TELEGRAM_BOT_TOKEN=
